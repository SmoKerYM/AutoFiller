{
  "manifest_version": 3,
  "name": "AutoFiller",
  "version": "1.0.0",
  "description": "Auto-fill job application forms with one click",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "images/icon-48.png",
      "96": "images/icon-96.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["fieldDetector.js", "fieldFiller.js", "dropdownHandler.js", "adapters/index.js", "adapters/generic.js", "content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png"
  }
}
